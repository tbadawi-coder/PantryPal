<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log In – PantryPal</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<header>
    <h1>PantryPal</h1>
</header>

<main class="page center">
    <div class="card">
        <h2>Log In</h2>

        <% if (errorFlash && errorFlash.length > 0) { %>
            <div class="flash flash-error">
                <% errorFlash.forEach(msg => { %>
                    <p><%= msg %></p>
                <% }) %>
            </div>
        <% } %>

        <% if (successFlash && successFlash.length > 0) { %>
            <div class="flash flash-success">
                <% successFlash.forEach(msg => { %>
                    <p><%= msg %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/users/login" method="POST">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <button type="submit" class="btn">Log In</button>
        </form>

        <p class="muted">Don't have an account? <a href="/users/new">Sign up</a></p>
    </div>
</main>

</body>
</html>
