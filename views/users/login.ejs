<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pantry</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<header>
    <nav class="nav">
        <a href="/" class="nav-logo" aria-label="PantryPal home">
            <img src="/images/pantrypal-logo-transparent-v3.png" alt="PantryPal" class="nav-logo-image">
        </a>
        <ul class="nav-links">
            <li><a href="/" data-page="home">Home</a></li>
            <li><a href="/pantry.html" data-page="pantry">Pantry</a></li>
            <li><a href="/results.html" data-page="results">Results</a></li>
            <li><a href="/planner.html" data-page="planner">Planner</a></li>
            <li><a href="/chat" data-page="chat">AI Chat</a></li>
            <li><a href="/about.html" data-page="about">About</a></li>
        </ul>
        <div class="nav-actions" id="nav-auth">
            <a href="http://localhost:3000/users/login" class="btn auth-btn auth-btn-secondary">Sign In</a>
            <a href="http://localhost:3000/users/new" class="btn auth-btn">Sign Up</a>
        </div>
    </nav>
</header>

<main class="page center">
    <div class="card">
        <h2>Log In</h2>

        <% if (errorFlash && errorFlash.length > 0) { %>
            <div class="flash flash-error">
                <% errorFlash.forEach(msg => { %>
                    <p><%= msg %></p>
                <% }) %>
            </div>
        <% } %>

        <% if (successFlash && successFlash.length > 0) { %>
            <div class="flash flash-success">
                <% successFlash.forEach(msg => { %>
                    <p><%= msg %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/users/login" method="POST">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <button type="submit" class="btn">Log In</button>
        </form>

        <p class="muted">Don't have an account? <a href="/users/new">Sign up</a></p>
    </div>
</main>

</body>
</html>
