<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipe AI Chat - PantryPal</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/chat.css">
</head>
<body>

<header>
    <nav class="nav">
        <a href="/" class="nav-logo" aria-label="PantryPal home">
            <img src="/images/pantrypal-logo-latest.png" alt="PantryPal" class="nav-logo-image">
        </a>
        <ul class="nav-links">
            <li><a href="/" data-page="home">Home</a></li>
            <li><a href="/pantry.html" data-page="pantry">Pantry</a></li>
            <li><a href="/results.html" data-page="results">Results</a></li>
            <li><a href="/planner.html" data-page="planner">Planner</a></li>
            <li><a href="/chat" data-page="chat">AI Chat</a></li>
            <li><a href="/about.html" data-page="about">About</a></li>
        </ul>
        <div class="nav-actions" id="nav-auth">
            <a href="http://localhost:3000/users/login" class="btn auth-btn auth-btn-secondary">Sign In</a>
            <a href="http://localhost:3000/users/new" class="btn auth-btn">Sign Up</a>
        </div>
    </nav>
    <div class="hero-header">
        <h1>🤖 Recipe AI Chat</h1>
        <p>Ask for recipe ideas based on your ingredients</p>
    </div>
</header>

<main class="page">
    <div class="chat-container">
        <div class="chat-box">
            <div id="messages" class="messages">
                <div class="message assistant-message">
                    <div class="message-content">
                        👋 Hi! I'm your Recipe AI Assistant. Tell me what ingredients you have, and I'll suggest delicious recipes you can make. What do you have on hand today?
                    </div>
                </div>
            </div>
            
            <div class="input-area">
                <form id="chatForm" class="chat-input-form">
                    <input 
                        type="text" 
                        id="messageInput" 
                        placeholder="E.g., I have chicken, rice, and tomatoes..." 
                        autocomplete="off"
                    >
                    <button type="submit" id="sendBtn" class="send-btn">
                        <span>Send</span>
                        <span class="spinner" id="spinner"></span>
                    </button>
                </form>
                <p class="input-hint">💡 Tip: List your available ingredients or ask for specific recipe ideas</p>
            </div>
        </div>
    </div>
</main>

<script>
    (function () {
        const current = "chat";
        document.querySelectorAll('.nav-links a[data-page="' + current + '"]')
            .forEach(function (link) {
                link.classList.add('active');
            });
    })();
</script>
<script>
    fetch('http://localhost:3000/api/me')
        .then(res => res.json())
        .then(data => {
            const navAuth = document.getElementById('nav-auth');
            if (data.loggedIn) {
                const initial = data.username ? data.username[0].toUpperCase() : '?';
                navAuth.innerHTML = `
                    <div class="avatar-wrap">
                        <div class="avatar">${initial}</div>
                        <div class="avatar-dropdown">
                            <span class="avatar-dropdown-name">${data.username}</span>
                            <a href="http://localhost:3000/users/profile">Profile</a>
                            <a href="http://localhost:3000/users/logout">Log Out</a>
                        </div>
                    </div>`;
            }
        })
        .catch(() => {});
</script>
<script src="/js/chat.js"></script>

</body>
</html>



